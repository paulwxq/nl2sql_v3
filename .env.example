# ==============================================================================
# NL2SQL v3 环境变量配置模板
# ==============================================================================
#
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写下面标记为 "⚠️ 需要填写" 的配置项
# 3. .env 文件已在 .gitignore 中，不会被提交到 Git
#
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL 数据库连接配置
# ------------------------------------------------------------------------------
# ⚠️ 需要填写：PostgreSQL 连接信息
DB_HOST=localhost           # 数据库主机地址
DB_PORT=5432                # 数据库端口
DB_NAME=nl2sql              # 数据库名称
DB_USER=postgres            # 数据库用户名
DB_PASSWORD=                # ⚠️ 必填：数据库密码

# ------------------------------------------------------------------------------
# Neo4j 图数据库连接配置
# ------------------------------------------------------------------------------
# ⚠️ 需要填写：Neo4j 连接信息
NEO4J_URI=bolt://localhost:7687   # Neo4j 连接URI
NEO4J_USER=neo4j                   # Neo4j 用户名
NEO4J_PASSWORD=                    # ⚠️ 必填：Neo4j 密码
NEO4J_DATABASE=neo4j               # Neo4j 数据库名

# ------------------------------------------------------------------------------
# 通义千问（Qwen/Dashscope）API 配置
# ------------------------------------------------------------------------------
# ⚠️ 需要填写：Qwen API 密钥
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=          # ⚠️ 必填：Dashscope API Key

# ------------------------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO              # 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/nl2sql.log    # 日志文件路径

# ------------------------------------------------------------------------------
# 开发/调试配置
# ------------------------------------------------------------------------------
DEBUG=false                 # 是否启用调试模式（true/false）
ENV=development             # 环境：development, staging, production

# ------------------------------------------------------------------------------
# 可选：LangSmith 监控配置（如不使用可留空）
# ------------------------------------------------------------------------------
LANGSMITH_API_KEY=          # LangSmith API Key（可选）
LANGSMITH_PROJECT=nl2sql-v3 # LangSmith 项目名称

# ------------------------------------------------------------------------------
# 可选：Redis 缓存配置（如不使用可留空）
# ------------------------------------------------------------------------------
REDIS_HOST=localhost        # Redis 主机
REDIS_PORT=6379             # Redis 端口
REDIS_PASSWORD=             # Redis 密码（可选）
REDIS_DB=0                  # Redis 数据库编号
